  "validation_rules": [
    {
      "rule": "all_reachable_detected",
      "description": "Every REACHABLE signal in every language must be detected and marked REACHABLE",
      "fail_condition": "Any REACHABLE signal shows NOT_REACHABLE or missing"
    },
    {
      "rule": "all_not_reachable_suppressed",
      "description": "Every NOT_REACHABLE signal must be marked NOT_REACHABLE (not REACHABLE, not UNKNOWN)",
      "fail_condition": "Any NOT_REACHABLE signal shows REACHABLE — false positive / precision regression"
    },
    {
      "rule": "unknown_not_false_positive",
      "description": "UNKNOWN signals (module on import graph, vuln func not called) must not be marked REACHABLE",
      "fail_condition": "UNKNOWN signal shows REACHABLE — false positive"
    },
    {
      "rule": "callgraph_coverage",
      "description": "NOT_REACHABLE results for CVE require call graph to have run. UNKNOWN for any UNKNOWN result is acceptable. NOT_REACHABLE for a dead-code module requires import/call graph traversal.",
      "canary_files": [
        "signal-matrix/javascript/signals/cve_not_reachable.js",
        "signal-matrix/go/signals/cve_dead.go",
        "signal-matrix/java/.../DeadCodeService.java"
      ]
    }
